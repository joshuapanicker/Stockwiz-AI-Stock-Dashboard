# Python
__pycache__/
*.pyc
*.pyo
.env

# Node
ui/node_modules/
ui/dist/

# Data (optional — remove these lines if you want to track your portfolio/criteria)
data/portfolio.json

# macOS
.DS_Store

# Universe SQLite DB (auto-populated at runtime)
data/universe.db
data/universe.db-shm
data/universe.db-wal

# Local AI usage tracking (only used when Supabase isn't configured)
data/ai_usage.json

# RAG filing index (auto-populated at runtime)
data/rag_chroma/
data/rag_index_state.json
data/rag_fts_state.json
data/hf_cache/

# Distillation training data (accumulated from live AI calls)
data/distill_log.jsonl

# Trained model artifacts (fine-tuned LoRA adapters — large binaries, must
# never be committed or deployed; store/serve them separately)
TrainedModelData/
*.safetensors
*.gguf
*.zip

# Editor
.vscode/

# Frontend env (contains Supabase keys)
ui/.env.local

# PDFs and documents
*.pdf
*.docx

# Personal AI architecture reference (kept local, never committed)
AI_ARCHITECTURE.md

# Design reference material (local inspiration only, never committed)
referenceWebsites/
