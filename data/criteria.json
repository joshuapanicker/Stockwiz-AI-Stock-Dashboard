{
  "buy": {
    "description": "Criteria for identifying stocks worth buying",
    "rules": [
      {
        "id": "near_52w_low",
        "description": "Stock is closer to its 52-week low than high (distance to low < 30%)",
        "field": "distance_to_low_pct",
        "operator": "lt",
        "value": 0.3
      },
      {
        "id": "positive_revenue_growth",
        "description": "Revenue growth is positive",
        "field": "revenue_growth",
        "operator": "gt",
        "value": 0
      },
      {
        "id": "reasonable_forward_pe",
        "description": "Forward PE is below 35 (not overvalued)",
        "field": "forward_pe",
        "operator": "lt",
        "value": 35
      },
      {
        "id": "positive_profit_margin",
        "description": "Profit margin is positive",
        "field": "profit_margin",
        "operator": "gt",
        "value": 0
      },
      {
        "id": "not_bearish_market",
        "description": "Market trend is not bearish",
        "field": "market_trend",
        "operator": "neq",
        "value": "bearish"
      }
    ],
    "min_rules_met": 4
  },
  "watch": {
    "description": "Criteria for stocks worth monitoring but not buying yet",
    "rules": [
      {
        "id": "moderate_distance_to_low",
        "description": "Stock is within 50% of its 52-week low",
        "field": "distance_to_low_pct",
        "operator": "lt",
        "value": 0.5
      },
      {
        "id": "positive_earnings_growth",
        "description": "Earnings growth is positive",
        "field": "earnings_growth",
        "operator": "gt",
        "value": 0
      },
      {
        "id": "acceptable_pe",
        "description": "Forward PE is below 50",
        "field": "forward_pe",
        "operator": "lt",
        "value": 50
      },
      {
        "id": "positive_operating_margin",
        "description": "Operating margin is positive",
        "field": "operating_margin",
        "operator": "gt",
        "value": 0
      }
    ],
    "min_rules_met": 3
  },
  "sell": {
    "description": "Criteria for deciding when to sell a held stock",
    "rules": [
      {
        "id": "near_52w_high",
        "description": "Stock is within 10% of its 52-week high",
        "field": "distance_to_high_pct",
        "operator": "lt",
        "value": 0.1
      },
      {
        "id": "pe_overvalued",
        "description": "Trailing PE exceeds 50 (overvalued)",
        "field": "trailing_pe",
        "operator": "gt",
        "value": 50
      },
      {
        "id": "revenue_growth_negative",
        "description": "Revenue growth has turned negative",
        "field": "revenue_growth",
        "operator": "lt",
        "value": 0
      },
      {
        "id": "bearish_market",
        "description": "Market trend is bearish",
        "field": "market_trend",
        "operator": "eq",
        "value": "bearish"
      },
      {
        "id": "profit_target",
        "description": "Stock has gained more than 40% from purchase price",
        "field": "gain_pct",
        "operator": "gt",
        "value": 0.4
      }
    ],
    "min_rules_met": 2
  },
  "watchlist": [
    "AAPL",
    "MSFT",
    "GOOGL",
    "AMZN",
    "NVDA",
    "META",
    "TSLA",
    "AMD",
    "NFLX",
    "CRM",
    "ADBE",
    "INTC",
    "PYPL",
    "SQ",
    "SHOP"
  ]
}